server {
    listen {{ nginx_http_port }} default_server;
    server_name _;

    location /health {
        add_header Content-Type text/plain;
        return 200 "ok from {{ inventory_hostname }}\n";
    }

    location / {
        return 301 https://$host$request_uri;
    }
}

server {
    listen {{ nginx_https_port }} ssl default_server;
    server_name {{ nginx_server_name }};

    ssl_certificate {{ nginx_tls_cert_path }};
    ssl_certificate_key {{ nginx_tls_key_path }};

    root {{ nginx_doc_root }};
    index index.html;

    location /health {
        add_header Content-Type text/plain;
        return 200 "ok from {{ inventory_hostname }}\n";
    }

    location / {
        try_files $uri $uri/ =404;
    }
}

